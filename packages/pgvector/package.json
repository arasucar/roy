{
  "name": "@roy/pgvector",
  "version": "0.1.0",
  "description": "Roy — pgvector storage + semantic compaction adapter.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "src"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
