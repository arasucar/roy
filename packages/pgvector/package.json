    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@roy/core": "workspace:*"
  },
  "peerDependencies": {
    "pg": "^8.11.0",
    "pgvector": "^0.2.0"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "@types/node": "^20.0.0",
    "@types/pg": "^8.11.0"
  }
